[Unit]
Description=Weston Wayland Compositor
Documentation=man:weston(1) man:weston.ini(5)

# 의존성: Plymouth가 완전히 종료될 때까지 기다림
After=multi-user.target plymouth-quit-timer.service plymouth-quit.service
Wants=plymouth-quit-timer.service

# DRM 장치가 있어야 시작
ConditionPathExists=/dev/dri/card0

[Service]
Type=simple

# 환경 변수 설정
Environment="XDG_RUNTIME_DIR=/run"
Environment="XDG_SESSION_TYPE=wayland"

# 시작 전: DRM 장치 확인 및 오래된 소켓 정리
ExecStartPre=/bin/sh -c 'while [ ! -c /dev/dri/card0 ]; do sleep 0.5; done'
ExecStartPre=/bin/rm -f /run/wayland-0
ExecStartPre=/bin/mkdir -p /run

# Weston 시작 (설정 파일 명시)
ExecStart=/usr/bin/weston --config=/etc/xdg/weston/weston.ini --log=/var/log/weston.log

# 시작 후: 소켓 생성 확인
ExecStartPost=/bin/sh -c 'for i in 1 2 3 4 5; do [ -S /run/wayland-0 ] && exit 0; sleep 0.5; done; exit 1'

# 실패 시 재시작 (최대 5번)
Restart=on-failure
RestartSec=2
StartLimitBurst=5
StartLimitIntervalSec=30

# 사용자 및 그룹
User=root
Group=root
SupplementaryGroups=video input render

# TTY 설정
TTYPath=/dev/tty7
TTYReset=yes
TTYVHangup=yes
TTYVTDisallocate=yes

# 작업 디렉토리
WorkingDirectory=/root

# 입출력
StandardInput=tty
StandardOutput=journal
StandardError=journal

# 타임아웃
TimeoutStartSec=30
TimeoutStopSec=10

# Utmp
UtmpIdentifier=tty7
UtmpMode=user

[Install]
WantedBy=graphical.target
